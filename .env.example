# Copy this file to `.env` and fill in real values.

# Database (SQLite for local dev; switch to postgresql for production).
DATABASE_URL="file:./dev.db"

# Auth.js (NextAuth v5). Generate a new one with: openssl rand -base64 32
AUTH_SECRET=""

# Base URL of the app (used by Auth.js for callbacks in production).
AUTH_URL="http://localhost:3000"

# Public runtime config exposed to the client.
NEXT_PUBLIC_APP_NAME="Next.js Full-Stack Template"
