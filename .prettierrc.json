{
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "printWidth": 80,
  "tabWidth": 2,
  "plugins": ["prettier-plugin-tailwindcss"],
  "tailwindFunctions": ["cn", "cva"],
  "overrides": [
    {
      "files": ["*.md", "*.mdx", "*.json", "*.yml", "*.yaml"],
      "options": {
        "proseWrap": "preserve"
      }
    }
  ]
}
